# Top-level .gitignore for the mono-repo (action + plugin).

# ----------------------------------------------------------
# macOS / OS metadata (safety net)
# ----------------------------------------------------------
.DS_Store
Thumbs.db

# ----------------------------------------------------------
# Build outputs (the ZIP is regenerated on every build, the source
# lives under wp-plugin/, the ZIP is only a distribution artifact).
# ----------------------------------------------------------
training-translation-tracker.zip
*.zip

# ----------------------------------------------------------
# Python (action/ folder)
# ----------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.tox/
.venv/
venv/
env/
pytest-cache-files-*/

# Local build outputs of the action (live on the data branch, not on main).
/action/tracker.json
/action/last-run.md
/action/data-hygiene.md
/action/_output/
/action/_data/

# ----------------------------------------------------------
# Editor / IDE
# ----------------------------------------------------------
.vscode/
.idea/
*.swp
*~
